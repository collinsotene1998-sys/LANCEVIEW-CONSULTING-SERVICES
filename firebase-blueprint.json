{
  "entities": {
    "SurplusSubmission": {
      "title": "Surplus Submission",
      "description": "Records of property inquiries for surplus funds recovery.",
      "type": "object",
      "properties": {
        "address": { "type": "string", "maxLength": 200 },
        "county": { "type": "string", "maxLength": 100 },
        "connection": { "type": "string", "enum": ["owner", "heir", "other"] },
        "ownerName": { "type": "string", "maxLength": 100 },
        "phone": { "type": "string", "maxLength": 20 },
        "email": { "type": "string", "format": "email", "maxLength": 150 },
        "submittedAt": { "type": "string" },
        "status": { "type": "string", "enum": ["audit_pending", "title_clearing", "motion_filed", "funds_disbursed"] },
        "caseNumber": { "type": "string", "maxLength": 20 },
        "estimatedFunds": { "type": "number" },
        "createdAt": { "type": "string" }
      },
      "required": ["address", "county", "connection", "ownerName", "phone", "email", "status", "caseNumber", "estimatedFunds", "createdAt"]
    },
    "B2BSubmission": {
      "title": "B2B Submission",
      "description": "Records of institutional investor and landlord consulting inquiries.",
      "type": "object",
      "properties": {
        "companyName": { "type": "string", "maxLength": 150 },
        "contactPerson": { "type": "string", "maxLength": 100 },
        "portfolioSize": { "type": "string", "enum": ["1-5", "6-20", "21+"] },
        "primaryGoal": { "type": "string", "enum": ["section8", "contracting", "both"] },
        "roadblockDescription": { "type": "string", "maxLength": 1000 },
        "submittedAt": { "type": "string" },
        "scheduledDate": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["companyName", "contactPerson", "portfolioSize", "primaryGoal", "roadblockDescription", "createdAt"]
    },
    "AiInquiry": {
      "title": "AI Inquiry",
      "description": "Inquiries generated by the AI Advisor widget.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "maxLength": 100 },
        "email": { "type": "string", "format": "email", "maxLength": 150 },
        "phone": { "type": "string", "maxLength": 20 },
        "details": { "type": "string", "maxLength": 2000 },
        "createdAt": { "type": "string" }
      },
      "required": ["name", "email", "phone", "details", "createdAt"]
    }
  },
  "firestore": {
    "surplus_submissions/{submissionId}": {
      "schema": { "$ref": "#/entities/SurplusSubmission" },
      "description": "Stores surplus funds recovery requests."
    },
    "b2b_submissions/{submissionId}": {
      "schema": { "$ref": "#/entities/B2BSubmission" },
      "description": "Stores B2B investor inquiries."
    },
    "ai_inquiries/{inquiryId}": {
      "schema": { "$ref": "#/entities/AiInquiry" },
      "description": "Stores inquiries collected by the AI Advisor."
    }
  }
}
